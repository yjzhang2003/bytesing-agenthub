{
  "name": "agenthub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "dev": "pnpm --filter @agenthub/web dev",
    "dev:control-plane": "pnpm --filter @agenthub/control-plane dev",
    "dev:desktop": "pnpm --filter @agenthub/desktop dev",
    "dev:runtime": "pnpm --filter @agenthub/desktop-runtime dev",
    "dev:web": "pnpm --filter @agenthub/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smoke:local": "node scripts/smoke-local.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "zod": "^4.2.1"
  }
}
