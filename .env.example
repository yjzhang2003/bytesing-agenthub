# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Local/demo runnable mode
AGENTHUB_AUTH_MODE=local-demo
AGENTHUB_LOCAL_AUTH_TOKEN=agenthub-local-demo-token
AGENTHUB_CONTROL_PLANE_URL=http://127.0.0.1:4310
AGENTHUB_PROVIDER_MODE=smoke
AGENTHUB_WORKSPACE_PATH=/absolute/path/to/agenthub
AGENTHUB_WORKSPACE_NAME=AgentHub

# Control plane
CONTROL_PLANE_PORT=4310
CONTROL_PLANE_PUBLIC_URL=http://127.0.0.1:4310
CONTROL_PLANE_WS_URL=ws://127.0.0.1:4310/runtime

# Desktop runtime
AGENTHUB_RUNTIME_DEVICE_NAME=AgentHub Desktop Runtime
AGENTHUB_CLAUDE_CODE_BIN=claude
AGENTHUB_RUNTIME_HEARTBEAT_SECONDS=15
AGENTHUB_RUNTIME_POLL_SECONDS=2
AGENTHUB_WEB_URL=http://127.0.0.1:5173

# Web/Desktop clients
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_CONTROL_PLANE_URL=http://127.0.0.1:4310
VITE_AGENTHUB_LOCAL_AUTH_TOKEN=agenthub-local-demo-token
