{
  "name": "@agenthub/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:electron": "tsx src/check-electron.ts",
    "dev": "pnpm check:electron && pnpm build && AGENTHUB_ELECTRON_ENTRY=1 electron dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agenthub/contracts": "workspace:*",
    "@supabase/supabase-js": "^2.106.1"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "typescript": "^5.9.3"
  }
}
